---
import type { Update } from '../i18n/content';
import { updates } from '../i18n/content';

interface Props { content?: Update[]; }
const { content = updates.en } = Astro.props;
---

<style>
  .update-row {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 8px 0;
    border-bottom: 1px dashed rgba(180,205,235,0.5);
  }
  .update-row:last-child { border-bottom: none; }
  .update-date {
    font-family: var(--font-source-code-pro);
    font-size: 11px;
    color: var(--ua-text-muted-light);
    letter-spacing: 1px;
  }
  .update-text {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ua-text-muted);
    line-height: 1.4;
  }
</style>

<div class="ua-panel fade-up" style="animation-delay:0.1s;">
  <div class="ua-toolbar">
    <img src="/images/xbutton.png" alt="" class="ua-xbtn" />
    <span class="ua-toolbar-title">UPDATES</span>
  </div>

  <div style="padding: 12px 14px;">
    {content.map(u => (
      <div class="update-row">
        <span class="update-date">{u.date}</span>
        <span class="update-text">{u.text}</span>
      </div>
    ))}
  </div>
</div>
