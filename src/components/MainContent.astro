---
import type { MainContent } from '../i18n/content';
import { main } from '../i18n/content';

interface Props { content?: MainContent; }
const { content = main.en } = Astro.props;
const { projects, skills } = content;
---

<style>
  .mc-panel {
    background: var(--ua-panel-bg);
    border: 1px solid var(--ua-panel-border);
    border-radius: var(--ua-panel-radius);
    box-shadow:
      0 0 0 1px rgba(255,255,255,0.75) inset,
      0 -1px 0 0 rgba(140,170,210,0.2) inset,
      0 6px 32px rgba(100,130,180,0.15),
      0 2px 8px rgba(100,130,180,0.1);
    overflow: hidden;
  }

  .mc-panel + .mc-panel { margin-top: 18px; }

  .mc-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 9px 16px;
    background: linear-gradient(180deg, #ffffff 0%, #edf1f7 100%);
    border-bottom: 1px solid var(--ua-panel-border);
    box-shadow: 0 1px 0 rgba(255,255,255,0.8) inset, 0 1px 3px rgba(140,170,210,0.1);
  }

  .mc-title {
    font-family: var(--font-space-age);
    font-size: 22px;
    background: var(--ua-gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: 1px;
  }

  .mc-toolbar-title {
    font-family: var(--font-sf-telegraphic);
    font-size: 15px;
    letter-spacing: 2px;
    color: var(--ua-toolbar-text);
    text-transform: uppercase;
  }

  .mc-xbtn {
    width: 20px;
    height: 20px;
    opacity: 0.7;
  }

  .mc-body {
    padding: 18px 20px 20px;
  }

  .mc-lead {
    font-family: var(--font-body);
    font-size: 14.5px;
    color: var(--ua-text-muted);
    line-height: 1.75;
  }

  .mc-highlight {
    color: #5a9fd8;
  }

  .mc-sep {
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(140,170,210,0.35) 20%, rgba(140,170,210,0.35) 80%, transparent 100%);
    box-shadow: 0 1px 0 rgba(255,255,255,0.8);
    margin: 14px 0;
  }

  .mc-h2 {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--ua-text-muted-light);
    letter-spacing: 2.5px;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .project-card {
    padding: 12px 14px 13px;
    border-radius: 14px;
    border: 1px solid rgba(190,210,230,0.6);
    background: linear-gradient(160deg, rgba(255,255,255,0.7) 0%, rgba(240,247,254,0.5) 100%);
    box-shadow:
      0 1px 4px rgba(100,140,190,0.07),
      inset 0 1px 2px rgba(255,255,255,0.9);
    transition: border-color 0.2s, box-shadow 0.2s;
    position: relative;
  }
  .project-card:hover {
    border-color: rgba(140,180,220,0.6);
    box-shadow:
      0 3px 12px rgba(80,140,200,0.1),
      inset 0 1px 2px rgba(255,255,255,0.9);
  }
  .project-card + .project-card { margin-top: 10px; }

  .project-name {
    font-family: var(--font-body);
    font-size: 14px;
    color: #6a9fd8;
    font-weight: 600;
    text-decoration: none;
  }
  .project-name:hover { color: #4a8fd4; text-decoration: underline; }

  .project-desc {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ua-text-muted);
    margin-top: 4px;
    line-height: 1.55;
  }
  .project-meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 9px;
    flex-wrap: wrap;
  }
  .project-star {
    font-family: var(--font-body);
    font-size: 11px;
    color: #bcc7d4;
    margin-left: auto;
    background: rgba(255,255,255,0.6);
    border: 1px solid rgba(190,210,230,0.6);
    border-radius: 8px;
    padding: 1px 7px;
    box-shadow: inset 0 1px 1px rgba(255,255,255,0.8);
  }

  .ua-tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 20px;
    border: 1px solid rgba(180,210,235,0.6);
    background: rgba(255,255,255,0.5);
    color: #8ab4d4;
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.5px;
    box-shadow: inset 0 1px 1px rgba(255,255,255,0.8);
  }

  .skill-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 9px;
  }
  .skill-name {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--ua-text-muted);
    width: 120px;
    flex-shrink: 0;
  }
  .skill-track {
    flex: 1;
    height: 5px;
    border-radius: 5px;
    background: rgba(140,170,210,0.18);
    border: 1px solid rgba(140,170,210,0.25);
    box-shadow: inset 0 1px 3px rgba(100,140,190,0.22), inset 0 0 1px rgba(100,140,190,0.15);
    overflow: hidden;
  }
  .skill-fill {
    height: 100%;
    border-radius: 5px;
    background: linear-gradient(90deg, #6aabf0, #a8d4ff);
    box-shadow: 0 0 6px rgba(106,171,240,0.5);
  }
  .skill-pct {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--ua-text-muted-light);
    width: 32px;
    text-align: right;
    flex-shrink: 0;
  }

  .blink-notice {
    font-size: 14.5px;
    color: #74a4db;
    font-family: var(--font-body);
    line-height: 1.75;
  }

  .blink-star {
    animation: blinker 1.5s infinite;
  }

  .fact-bar {
    padding: 7px 18px;
    background: rgba(255,255,255,0.4);
    border-top: 1px solid var(--ua-panel-border);
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--ua-text-muted-light);
    letter-spacing: 1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
</style>

<!-- WELCOME PANEL -->
<div class="mc-panel fade-up">
  <div class="mc-toolbar">
    <span class="mc-title">welcome</span>
    <img src="/images/xbutton.png" alt="" class="mc-xbtn" />
  </div>

  <div class="mc-body">
    <p class="mc-lead" set:html={content.welcomeP1} />
    <span class="mc-sep"></span>
    <p class="mc-lead" set:html={content.welcomeP2} />
    <span class="mc-sep"></span>
    <span class="blink-notice">
      <span class="blink-star">✦</span> {content.blinkNotice} <span class="blink-star">✦</span>
    </span>
  </div>

  <div class="fact-bar">{content.factBar}</div>
</div>

<!-- PROJECTS PANEL -->
<div class="mc-panel fade-up" style="animation-delay:0.08s;">
  <div class="mc-toolbar">
    <span class="mc-title">projects</span>
    <img src="/images/xbutton.png" alt="" class="mc-xbtn" />
  </div>

  <div class="mc-body">
    <p class="mc-h2">{content.projectsLabel}</p>
    {projects.map(p => (
      <div class="project-card">
        <div style="display:flex;align-items:baseline;gap:8px;">
          <a href={p.href} class="project-name">{p.name}</a>
          <span class="project-star"><svg width="9" height="9" viewBox="0 0 10 10" fill="currentColor" style="vertical-align:middle;position:relative;top:-0.5px;margin-right:2px;"><polygon points="5,0.5 6.2,3.8 9.8,3.8 6.9,5.9 8,9.2 5,7.2 2,9.2 3.1,5.9 0.2,3.8 3.8,3.8"/></svg>{p.star}</span>
        </div>
        <p class="project-desc">{p.desc}</p>
        <div class="project-meta">
          {p.tags.map(t => <span class="ua-tag">{t}</span>)}
        </div>
      </div>
    ))}
  </div>
</div>

<!-- SKILLS PANEL -->
<div class="mc-panel fade-up" style="animation-delay:0.16s;">
  <div class="mc-toolbar">
    <span class="mc-title">skills</span>
    <img src="/images/xbutton.png" alt="" class="mc-xbtn" />
  </div>

  <div class="mc-body">
    <p class="mc-h2">{content.proficiencyLabel}</p>
    {skills.map(s => (
      <div class="skill-row">
        <span class="skill-name">{s.name}</span>
        <div class="skill-track">
          <div class="skill-fill" style={`width:${s.level}%`}></div>
        </div>
        <span class="skill-pct">{s.level}%</span>
      </div>
    ))}
  </div>
</div>
