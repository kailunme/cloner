---
import type { SidebarContent } from '../i18n/content';
import { sidebar } from '../i18n/content';
import IPodPlayer from './iPodPlayer';

interface Props { content?: SidebarContent; }
const { content = sidebar.en } = Astro.props;
---

<style>
  .stat-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 7px 0;
    border-bottom: 1px dashed rgba(180,205,235,0.5);
    font-family: var(--font-body);
    font-size: 13px;
  }
  .stat-row:last-child { border-bottom: none; }
  .stat-label { color: var(--ua-text-muted-light); }
  .stat-value {
    font-family: var(--font-body);
    font-size: 11px;
    color: #8aafc8;
    background: linear-gradient(180deg, #2a3a4a 0%, #1e2d3c 100%);
    border: 1px solid #1a2a38;
    border-radius: 5px;
    padding: 2px 8px;
    box-shadow:
      inset 0 1px 3px rgba(0,0,0,0.35),
      inset 0 0 6px rgba(0,10,20,0.2),
      0 1px 0 rgba(255,255,255,0.12);
    letter-spacing: 0.5px;
    text-shadow: 0 0 6px rgba(106,171,240,0.4);
  }

  .button-gif-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 10px 0 4px;
  }
  .site-button-img {
    opacity: 0.75;
    image-rendering: pixelated;
    transition: opacity 0.2s;
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(100,140,190,0.18), 0 1px 2px rgba(100,140,190,0.1);
  }
  .site-button-img:hover { opacity: 1; }
</style>

<!-- NOW PLAYING (iPod nano) -->
<div class="ua-panel fade-up" style="animation-delay:0.18s;">
  <div class="ua-toolbar">
    <img src="/images/xbutton.png" alt="" class="ua-xbtn" />
    <span class="ua-toolbar-title">NOW PLAYING</span>
  </div>
  <div style="padding:14px 10px; display:flex; justify-content:center;">
    <IPodPlayer title={content.nowPlayingTitle} artist={content.nowPlayingArtist} client:load />
  </div>
</div>

<!-- STATS -->
<div class="ua-panel fade-up" style="animation-delay:0.26s;">
  <div class="ua-toolbar">
    <img src="/images/xbutton.png" alt="" class="ua-xbtn" />
    <span class="ua-toolbar-title">{content.statsTitle}</span>
  </div>
  <div style="padding:10px 14px;">
    {content.stats.map(s => (
      <div class="stat-row">
        <span class="stat-label">{s.label}</span>
        <span class="stat-value">{s.value}</span>
      </div>
    ))}
  </div>
</div>

<!-- SITE BUTTON -->
<div class="ua-panel fade-up" style="animation-delay:0.34s;">
  <div class="ua-toolbar">
    <img src="/images/xbutton.png" alt="" class="ua-xbtn" />
    <span class="ua-toolbar-title">{content.buttonTitle}</span>
  </div>
  <div class="button-gif-wrap">
    <img src="/images/UnicodeAngelButton.gif" alt="site button" class="site-button-img" />
    <span style="font-family:var(--font-body);font-size:11px;color:var(--ua-text-muted-light);letter-spacing:1px;">
      {content.linkBackLabel}
    </span>
  </div>
</div>
