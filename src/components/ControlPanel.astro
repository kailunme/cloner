---
import SynthPanel from './SynthPanel';

interface Props { current: 'en' | 'zh' | 'ja'; }
const { current } = Astro.props;
---

<style>
  .ctrl-panel {
    background: var(--ua-panel-bg);
    border: 1px solid var(--ua-panel-border);
    border-radius: var(--ua-panel-radius);
    box-shadow: var(--ua-panel-shadow);
    padding: 12px 14px;
    margin-top: 16px;
  }

  @media (max-width: 700px) {
    .ctrl-panel { margin-top: 0; }
  }
</style>

<div class="ctrl-panel">
  <SynthPanel current={current} client:load />
</div>
