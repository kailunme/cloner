---
---

<div
  style="position:relative;margin-top:10px;top:-20px;left:20px;width:180px;background-image:linear-gradient(90deg,#fafbfb 0%,#f7f7f7 50%,#fafbfb 100%);border:1.5px solid #c9c9c9;border-radius:22px;z-index:1;box-shadow:inset 0px -5px 5px -4px #dadada,0px 0px 5px 0px #dadada;"
>
  <div class="ua-toolbar" style="position:relative;height:15px;margin:0 3px;border-radius:25px 25px 15px 15px;padding:12px 16px;">
    <img
      src="/images/xbutton.png"
      alt="close"
      style="position:relative;margin-top:-1.5%;left:-7px;float:left;height:24px;width:auto;z-index:100;"
    />
    <span style="position:relative;color:#555a61;font-family:var(--font-sf-telegraphic);font-size:24px;letter-spacing:1px;line-height:30px;float:right;z-index:100;">
      MOOD
    </span>
  </div>

  <!-- Feeling -->
  <div class="ua-inner" style="height:30px;padding-left:0;padding-right:0;padding-bottom:0;margin-top:40px;">
    <span style="top:-22px;left:10px;font-family:var(--font-aldrich);font-size:12px;color:#9da7b3;position:relative;display:block;">
      feeling
    </span>
    <img
      src="https://moods.imood.com/display/uname-yokiie/fg-89929c/bg-fafafb/imood.gif"
      alt="imood"
      style="position:relative;top:-7px;margin:auto;display:block;"
    />
  </div>

  <!-- Status -->
  <div class="ua-inner" style="margin-top:0;">
    <span style="top:-22px;left:-10px;font-family:var(--font-aldrich);font-size:12px;color:#9da7b3;position:relative;display:block;">
      status
    </span>
    <div>
      <span style="color:#9da7b3;font-family:var(--font-aldrich);font-size:12px;">
        status loading...
      </span>
    </div>
  </div>
</div>
