---
import type { NavContent } from '../i18n/content';
import { nav } from '../i18n/content';

interface Props { content?: NavContent; }
const { content = nav.en } = Astro.props;
---

<style>
  .navbar-wrap {
    background: var(--ua-panel-bg);
    border: 1px solid var(--ua-panel-border);
    border-radius: var(--ua-panel-radius);
    box-shadow: var(--ua-panel-shadow);
    overflow: hidden;
  }

  .navbar-header {
    padding: 18px 16px 12px;
    background: linear-gradient(180deg, #ffffff 0%, #f0f4fa 100%);
    border-bottom: 1px solid var(--ua-panel-border);
    text-align: center;
  }

  .navbar-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a8d4ff, #6aabf0);
    margin: 0 auto 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    border: 2px solid rgba(100,170,240,0.4);
    box-shadow: 0 2px 12px rgba(80,140,200,0.2);
  }

  .navbar-name {
    font-family: var(--font-space-age);
    font-size: 22px;
    background: var(--ua-gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: 2px;
  }

  .navbar-handle {
    font-family: var(--font-source-code-pro);
    font-size: 12px;
    color: var(--ua-text-muted);
    letter-spacing: 1px;
    margin-top: 3px;
  }

  .navbar-nav {
    padding: 8px 0;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 16px;
    font-family: var(--font-forced-square);
    font-size: 15px;
    color: var(--ua-text-muted);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
    position: relative;
  }

  .nav-item::before {
    content: '';
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--ua-panel-border);
    flex-shrink: 0;
    transition: background 0.15s;
  }

  .nav-item:hover {
    color: #5a9fd8;
    background: rgba(100,170,240,0.07);
  }

  .nav-item:hover::before { background: #6aabf0; }

  .nav-item.active {
    color: #4a8fd4;
  }
  .nav-item.active::before {
    background: #6aabf0;
    box-shadow: 0 0 6px rgba(100,170,240,0.5);
  }

  .navbar-footer {
    padding: 10px 16px;
    border-top: 1px solid var(--ua-panel-border);
    display: flex;
    gap: 10px;
    justify-content: center;
  }

  .social-link {
    width: 36px;
    height: 32px;
    border-radius: 12px;
    border: 1px solid var(--ua-panel-border);
    background: linear-gradient(180deg, #ffffff, #f0f4fa);
    box-shadow: 0 1px 3px rgba(180,200,230,0.4), inset 0 -1px 3px rgba(180,200,230,0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, box-shadow 0.15s, border-color 0.15s, opacity 0.15s;
    text-decoration: none;
    user-select: none;
  }
  .social-link img {
    width: 17px;
    height: 17px;
    opacity: 0.45;
    transition: opacity 0.15s;
  }
  .social-link:hover {
    background: linear-gradient(180deg, #f0f6ff, #e8f0fa);
    box-shadow: 0 2px 6px rgba(100,160,220,0.2), inset 0 -1px 3px rgba(180,200,230,0.3);
    border-color: rgba(100,160,220,0.5);
  }
  .social-link:hover img {
    opacity: 0.75;
  }

  #loadercircle { animation: rotate 2s linear infinite; }
</style>

<div class="navbar-wrap">
  <div class="navbar-header">
    <div class="navbar-avatar">
      <img src="/images/loadercircle.png" id="loadercircle" alt="" width="36" height="36" style="opacity:0.7;image-rendering:crisp-edges;" />
    </div>
    <div class="navbar-name">KAI</div>
    <div class="navbar-handle">{content.handle}</div>
  </div>

  <nav class="navbar-nav">
    {content.links.map(link => (
      <a href={link.href} class={`nav-item${link.active ? ' active' : ''}`}>
        {link.label}
      </a>
    ))}
  </nav>

  <div class="navbar-footer">
    <a href="https://github.com" target="_blank" class="social-link" title="GitHub">
      <img src="/images/icon/github-logo.svg" alt="GitHub" />
    </a>
    <a href="https://instagram.com" target="_blank" class="social-link" title="Instagram">
      <img src="/images/icon/instagram-logo.svg" alt="Instagram" />
    </a>
    <a href="mailto:hello@example.com" class="social-link" title="Email">
      <img src="/images/icon/envelope-simple.svg" alt="Email" />
    </a>
  </div>
</div>
