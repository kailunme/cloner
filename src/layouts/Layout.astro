---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'u n i c o d e a n g e l',
  description = 'A digital space blending the digital with the organic.',
  lang,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href="/seo/favicon.ico" />
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Aldrich&family=Source+Code+Pro:wght@200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class="ua-body" data-lang={lang}>
    <slot />
  </body>
  <script>
    function applyLang() {
      const path = window.location.pathname;
      let locale = 'en';
      if (path.startsWith('/zh')) {
        document.body.setAttribute('data-lang', 'zh');
        locale = 'zh';
      } else if (path.startsWith('/ja')) {
        document.body.setAttribute('data-lang', 'ja');
        locale = 'ja';
      } else {
        document.body.removeAttribute('data-lang');
      }
      document.querySelectorAll('.lang-btn').forEach(btn => {
        const href = btn.getAttribute('href') ?? '';
        const match =
          (locale === 'en' && (href === '/' || href === '')) ||
          (locale === 'zh' && href.startsWith('/zh')) ||
          (locale === 'ja' && href.startsWith('/ja'));
        btn.classList.toggle('active', match);
      });
      // Force np-title to re-inherit --font-body after cache restore
      document.querySelectorAll('.np-title').forEach(el => {
        (el as HTMLElement).style.fontFamily = '';
        (el as HTMLElement).style.fontFamily = 'var(--font-body)';
      });
    }
    document.addEventListener('astro:after-swap', applyLang);
  </script>
</html>
