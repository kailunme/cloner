---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import MainContent from '../components/MainContent.astro';
import UpdatesWindow from '../components/UpdatesWindow.astro';
import RightSidebar from '../components/RightSidebar.astro';
import ControlPanel from '../components/ControlPanel.astro';
---

<Layout>
  <div class="bg-video-container" transition:persist="bg-video">
    <video id="bg-video" autoplay muted loop playsinline class="bg-video">
      <source src="/videos/background.mp4" type="video/mp4" />
    </video>
  </div>

  <div class="site-grid">
    <!-- LEFT -->
    <div class="col-left">
      <NavBar />
      <ControlPanel current="en" />
    </div>

    <!-- MIDDLE -->
    <div class="col-mid">
      <MainContent />
    </div>

    <!-- RIGHT -->
    <div class="col-right">
      <UpdatesWindow />
      <RightSidebar />
    </div>
  </div>
</Layout>
